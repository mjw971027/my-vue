<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mjw.vueback.demos.web.mapper.TCompanyMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.mjw.vueback.demos.web.entity.TCompany">
        <id column="CODE" property="code" />
        <result column="DESC_CHN" property="descChn" />
        <result column="DESC_ENG" property="descEng" />
        <result column="STATUS" property="status" />
        <result column="CREATE_USER_ID" property="createUserId" />
        <result column="CREATE_DATE" property="createDate" />
        <result column="UPDATE_USER_ID" property="updateUserId" />
        <result column="UPDATE_DATE" property="updateDate" />
        <result column="REMARK" property="remark" />
    </resultMap>
    
    <!-- 查询所有有效公司 -->
    <select id="selectAllValid" resultMap="BaseResultMap">
        SELECT * FROM T_COMPANY WHERE STATUS = '01' ORDER BY CODE
    </select>
    
    <!-- 根据代码查询 -->
    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT * FROM T_COMPANY WHERE CODE = #{code}
    </select>
    
    <!-- 根据条件查询 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM T_COMPANY
        <where>
            <if test="code != null and code != ''">
                AND CODE = #{code}
            </if>
            <if test="status != null and status != ''">
                AND STATUS = #{status}
            </if>
        </where>
        ORDER BY CODE
    </select>
    
    <!-- 插入 -->
    <insert id="insert" parameterType="com.mjw.vueback.demos.web.entity.TCompany">
        INSERT INTO T_COMPANY (
            CODE, DESC_CHN, DESC_ENG, STATUS,
            CREATE_USER_ID, CREATE_DATE, UPDATE_USER_ID, UPDATE_DATE, REMARK
        ) VALUES (
            #{code}, #{descChn}, #{descEng}, #{status},
            #{createUserId}, #{createDate}, #{updateUserId}, #{updateDate}, #{remark}
        )
    </insert>
    
    <!-- 根据代码更新 -->
    <update id="updateByCode" parameterType="com.mjw.vueback.demos.web.entity.TCompany">
        UPDATE T_COMPANY
        <set>
            <if test="descChn != null">DESC_CHN = #{descChn},</if>
            <if test="descEng != null">DESC_ENG = #{descEng},</if>
            <if test="status != null">STATUS = #{status},</if>
            <if test="updateUserId != null">UPDATE_USER_ID = #{updateUserId},</if>
            <if test="updateDate != null">UPDATE_DATE = #{updateDate},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </set>
        WHERE CODE = #{code}
    </update>
    
    <!-- 根据代码删除 -->
    <delete id="deleteByCode">
        DELETE FROM T_COMPANY WHERE CODE = #{code}
    </delete>
    
    <!-- 插入非空字段 -->
    <insert id="insertSelective" parameterType="com.mjw.vueback.demos.web.entity.TCompany">
        INSERT INTO T_COMPANY
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null">CODE,</if>
            <if test="descChn != null">DESC_CHN,</if>
            <if test="descEng != null">DESC_ENG,</if>
            <if test="status != null">STATUS,</if>
            <if test="createUserId != null">CREATE_USER_ID,</if>
            <if test="createDate != null">CREATE_DATE,</if>
            <if test="updateUserId != null">UPDATE_USER_ID,</if>
            <if test="updateDate != null">UPDATE_DATE,</if>
            <if test="remark != null">REMARK,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="code != null">#{code},</if>
            <if test="descChn != null">#{descChn},</if>
            <if test="descEng != null">#{descEng},</if>
            <if test="status != null">#{status},</if>
            <if test="createUserId != null">#{createUserId},</if>
            <if test="createDate != null">#{createDate},</if>
            <if test="updateUserId != null">#{updateUserId},</if>
            <if test="updateDate != null">#{updateDate},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>
    
    <!-- 根据代码更新非空字段 -->
    <update id="updateByCodeSelective" parameterType="com.mjw.vueback.demos.web.entity.TCompany">
        UPDATE T_COMPANY
        <set>
            <if test="descChn != null">DESC_CHN = #{descChn},</if>
            <if test="descEng != null">DESC_ENG = #{descEng},</if>
            <if test="status != null">STATUS = #{status},</if>
            <if test="updateUserId != null">UPDATE_USER_ID = #{updateUserId},</if>
            <if test="updateDate != null">UPDATE_DATE = #{updateDate},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </set>
        WHERE CODE = #{code}
    </update>
    
</mapper>
