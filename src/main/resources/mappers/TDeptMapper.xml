<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mjw.vueback.demos.web.mapper.TDeptMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.mjw.vueback.demos.web.entity.TDept">
        <id column="ORGN_CD" property="orgnCd" />
        <result column="ORGN_DESC" property="orgnDesc" />
        <result column="SUPER_ORGN_CD" property="superOrgnCd" />
        <result column="ORGN_TYPE" property="orgnType" />
        <result column="STATUS" property="status" />
        <result column="CREATE_USER_ID" property="createUserId" />
        <result column="CREATE_DATE" property="createDate" />
        <result column="UPDATE_USER_ID" property="updateUserId" />
        <result column="UPDATE_DATE" property="updateDate" />
        <result column="REMARK" property="remark" />
    </resultMap>
    
    <!-- 根据上级组织代码查询所有有效部门 -->
    <select id="selectBySuperOrgnCd" resultMap="BaseResultMap">
        SELECT * FROM T_DEPT 
        WHERE SUPER_ORGN_CD = #{superOrgnCd} AND STATUS = '01'
        ORDER BY ORGN_CD
    </select>
    
    <!-- 根据组织代码查询 -->
    <select id="selectByOrgnCd" resultMap="BaseResultMap">
        SELECT * FROM T_DEPT WHERE ORGN_CD = #{orgnCd}
    </select>
    
    <!-- 根据条件查询 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM T_DEPT
        <where>
            <if test="orgnCd != null and orgnCd != ''">
                AND ORGN_CD = #{orgnCd}
            </if>
            <if test="superOrgnCd != null and superOrgnCd != ''">
                AND SUPER_ORGN_CD = #{superOrgnCd}
            </if>
            <if test="status != null and status != ''">
                AND STATUS = #{status}
            </if>
        </where>
        ORDER BY ORGN_CD
    </select>
    
    <!-- 插入 -->
    <insert id="insert" parameterType="com.mjw.vueback.demos.web.entity.TDept">
        INSERT INTO T_DEPT (
            ORGN_CD, ORGN_DESC, SUPER_ORGN_CD, ORGN_TYPE, STATUS,
            CREATE_USER_ID, CREATE_DATE, UPDATE_USER_ID, UPDATE_DATE, REMARK
        ) VALUES (
            #{orgnCd}, #{orgnDesc}, #{superOrgnCd}, #{orgnType}, #{status},
            #{createUserId}, #{createDate}, #{updateUserId}, #{updateDate}, #{remark}
        )
    </insert>
    
    <!-- 根据组织代码更新 -->
    <update id="updateByOrgnCd" parameterType="com.mjw.vueback.demos.web.entity.TDept">
        UPDATE T_DEPT
        <set>
            <if test="orgnDesc != null">ORGN_DESC = #{orgnDesc},</if>
            <if test="superOrgnCd != null">SUPER_ORGN_CD = #{superOrgnCd},</if>
            <if test="orgnType != null">ORGN_TYPE = #{orgnType},</if>
            <if test="status != null">STATUS = #{status},</if>
            <if test="updateUserId != null">UPDATE_USER_ID = #{updateUserId},</if>
            <if test="updateDate != null">UPDATE_DATE = #{updateDate},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </set>
        WHERE ORGN_CD = #{orgnCd}
    </update>
    
    <!-- 根据组织代码删除 -->
    <delete id="deleteByOrgnCd">
        DELETE FROM T_DEPT WHERE ORGN_CD = #{orgnCd}
    </delete>
    
    <!-- 插入非空字段 -->
    <insert id="insertSelective" parameterType="com.mjw.vueback.demos.web.entity.TDept">
        INSERT INTO T_DEPT
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orgnCd != null">ORGN_CD,</if>
            <if test="orgnDesc != null">ORGN_DESC,</if>
            <if test="superOrgnCd != null">SUPER_ORGN_CD,</if>
            <if test="orgnType != null">ORGN_TYPE,</if>
            <if test="status != null">STATUS,</if>
            <if test="createUserId != null">CREATE_USER_ID,</if>
            <if test="createDate != null">CREATE_DATE,</if>
            <if test="updateUserId != null">UPDATE_USER_ID,</if>
            <if test="updateDate != null">UPDATE_DATE,</if>
            <if test="remark != null">REMARK,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orgnCd != null">#{orgnCd},</if>
            <if test="orgnDesc != null">#{orgnDesc},</if>
            <if test="superOrgnCd != null">#{superOrgnCd},</if>
            <if test="orgnType != null">#{orgnType},</if>
            <if test="status != null">#{status},</if>
            <if test="createUserId != null">#{createUserId},</if>
            <if test="createDate != null">#{createDate},</if>
            <if test="updateUserId != null">#{updateUserId},</if>
            <if test="updateDate != null">#{updateDate},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>
    
    <!-- 根据组织代码更新非空字段 -->
    <update id="updateByOrgnCdSelective" parameterType="com.mjw.vueback.demos.web.entity.TDept">
        UPDATE T_DEPT
        <set>
            <if test="orgnDesc != null">ORGN_DESC = #{orgnDesc},</if>
            <if test="superOrgnCd != null">SUPER_ORGN_CD = #{superOrgnCd},</if>
            <if test="orgnType != null">ORGN_TYPE = #{orgnType},</if>
            <if test="status != null">STATUS = #{status},</if>
            <if test="updateUserId != null">UPDATE_USER_ID = #{updateUserId},</if>
            <if test="updateDate != null">UPDATE_DATE = #{updateDate},</if>
            <if test="remark != null">REMARK = #{remark},</if>
        </set>
        WHERE ORGN_CD = #{orgnCd}
    </update>
    
</mapper>
