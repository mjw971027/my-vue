            UNIT, DEMAND_QTY, FINAL_DEMAND_QTY, MATERIAL_COST, MATERIAL_SOURCES,
            REMARK, QUALITY, THK1, THK2, W1,
            W2, L, CREATE_NODE, CREATE_USER_ID, CREATE_DATE,
            UPDATE_USER_ID, UPDATE_DATE, BO_ID
        ) VALUES (
            #{guid}, #{componentsId}, #{activation}, #{materialNo}, #{materialName},
            #{unit}, #{demandQty}, #{finalDemandQty}, #{materialCost}, #{materialSources},
            #{remark}, #{quality}, #{thk1}, #{thk2}, #{w1},
            #{w2}, #{l}, #{createNode}, #{createUserId}, #{createDate},
            #{updateUserId}, #{updateDate}, #{boId}
        )
    </insert>
    
