        <result column="UPDATE_DATE" property="updateDate" />
        <result column="BO_ID" property="boId" />
    </resultMap>
    
    <!-- 根据 GUID 查询 -->
    <select id="selectByGuid" resultMap="BaseResultMap">
        SELECT * FROM T_COMPONENTS_LINE WHERE GUID = #{guid}
    </select>
    
    <!-- 根据工装申请ID查询明细列表 -->
    <select id="selectByComponentsId" resultMap="BaseResultMap">
        SELECT * FROM T_COMPONENTS_LINE WHERE COMPONENTS_ID = #{componentsId}
    </select>
    
    <!-- 根据条件查询列表 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT * FROM T_COMPONENTS_LINE
        <where>
            <if test="guid != null and guid != ''">
                AND GUID = #{guid}
            </if>
            <if test="componentsId != null and componentsId != ''">
                AND COMPONENTS_ID = #{componentsId}
            </if>
            <if test="materialNo != null and materialNo != ''">
                AND MATERIAL_NO = #{materialNo}
            </if>
            <if test="materialName != null and materialName != ''">
                AND MATERIAL_NAME LIKE CONCAT('%', #{materialName}, '%')
            </if>
            <if test="createUserId != null and createUserId != ''">
                AND CREATE_USER_ID = #{createUserId}
            </if>
        </where>
        ORDER BY CREATE_DATE DESC
    </select>
    <select id="getNewMactNo" resultType="java.lang.String">
        SELECT
            CONCAT(
                    'MACT',
                    DATE_FORMAT(NOW(), '%Y%m%d'),
                    LPAD(IFNULL(MAX(SUBSTRING(MATERIAL_NO, 13)), 0) + 1, 3, '0')
            ) AS NEW_MATERIAL_NO
        FROM t_components_line
        WHERE MATERIAL_NO LIKE CONCAT('MACT', DATE_FORMAT(NOW(), '%Y%m%d'), '%');
    </select>

